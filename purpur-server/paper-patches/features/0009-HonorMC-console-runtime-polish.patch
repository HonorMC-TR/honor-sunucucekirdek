From: HonorMC <dev@honormc.local>
Date: Wed, 1 Jul 2026 16:37:14 +0300
Subject: [PATCH] HonorMC console runtime polish


diff --git a/src/log4jPlugins/java/io/papermc/paper/console/HonorMCConsoleStyles.java b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCConsoleStyles.java
index 7c7c8aa3a0426466dd0278928745d323addd5179..90ea8926306d206e426e9163d78fc5948d85ef39 100644
--- a/src/log4jPlugins/java/io/papermc/paper/console/HonorMCConsoleStyles.java
+++ b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCConsoleStyles.java
@@ -23,7 +23,7 @@ final class HonorMCConsoleStyles {
     }
 
     static String label(final LogEvent event) {
-        if (isChat(event)) {
+        if (isPlayerLine(event)) {
             return "OYUNCU";
         }
 
@@ -44,7 +44,7 @@ final class HonorMCConsoleStyles {
     }
 
     static String messageColor(final LogEvent event) {
-        if (isChat(event)) {
+        if (isPlayerLine(event)) {
             return CYAN;
         }
 
@@ -63,7 +63,7 @@ final class HonorMCConsoleStyles {
     }
 
     private static String labelColor(final LogEvent event) {
-        if (isChat(event)) {
+        if (isPlayerLine(event)) {
             return CYAN_BOLD;
         }
 
@@ -82,4 +82,22 @@ final class HonorMCConsoleStyles {
         final Marker marker = event.getMarker();
         return marker != null && (CHAT_MARKER.equals(marker.getName()) || marker.isInstanceOf(CHAT_MARKER));
     }
+
+    private static boolean isPlayerLine(final LogEvent event) {
+        if (isChat(event)) {
+            return true;
+        }
+
+        if (event.getMessage() == null) {
+            return false;
+        }
+
+        final String message = event.getMessage().getFormattedMessage();
+        return message.startsWith("Oyuncu UUID bilgisi:")
+            || message.contains(" oyuna katildi")
+            || message.contains(" oyundan ayrildi")
+            || message.contains(" joined the game")
+            || message.contains(" left the game")
+            || message.contains(" logged in with entity id ");
+    }
 }
diff --git a/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java
index 2e7a3d9c2b4d4c2e23cd516540b2c76df7f35bfa..bc299a0c2d3d6a979d3e1cc6168f106d5a3ed486 100644
--- a/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java
+++ b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java
@@ -28,7 +28,7 @@ public final class HonorMCMessageConverter extends LogEventPatternConverter {
             formatter.format(event, toAppendTo);
         }
 
-        final String content = toAppendTo.substring(start);
+        final String content = translateContent(toAppendTo.substring(start));
         toAppendTo.setLength(start);
         toAppendTo
             .append(HonorMCConsoleStyles.messageColor(event))
@@ -45,4 +45,67 @@ public final class HonorMCMessageConverter extends LogEventPatternConverter {
         final PatternParser parser = PatternLayout.createPatternParser(config);
         return new HonorMCMessageConverter(parser.parse(options[0]));
     }
+
+    private static String translateContent(final String content) {
+        String translated = content
+            .replace("Environment: Environment[", "Mojang ortam bilgisi: Environment[")
+            .replace("sessionHost=", "oturumSunucusu=")
+            .replace("servicesHost=", "servisSunucusu=")
+            .replace("profilesHost=", "profilSunucusu=")
+            .replace("name=", "ad=")
+            .replace("Loaded recipes", "Tarifler yuklendi")
+            .replace("Loading properties", "Ayarlar yukleniyor")
+            .replace("Generating keypair", "Sunucu anahtar cifti olusturuluyor")
+            .replace("YOU ARE RUNNING THIS SERVER AS AN ADMINISTRATIVE OR ROOT USER. THIS IS NOT ADVISED.", "SUNUCU YONETICI/ROOT YETKISIYLE CALISIYOR. BU ONERILMEZ.")
+            .replace("YOU ARE OPENING YOURSELF UP TO POTENTIAL RISKS WHEN DOING THIS.", "Bu sekilde calistirmak gereksiz guvenlik riski olusturur.")
+            .replace("FOR MORE INFORMATION, SEE https://madelinemiller.dev/blog/root-minecraft-server/", "Detay: https://madelinemiller.dev/blog/root-minecraft-server/")
+            .replace("Paper: Using Java compression from Velocity.", "Paper: Velocity Java sikistirma katmani kullaniliyor.")
+            .replace("Paper: Using Java cipher from Velocity.", "Paper: Velocity Java sifreleme katmani kullaniliyor.")
+            .replace("Running delayed init tasks", "Gecikmeli baslangic gorevleri calistiriliyor")
+            .replace("For help, type \"help\"", "Yardim icin \"help\" yaz")
+            .replace("All chunks are saved", "Tum chunklar kaydedildi")
+            .replace("All dimensions are saved", "Tum boyutlar kaydedildi")
+            .replace("Not Secure", "Guvenli Degil")
+            .replace("Loading server plugin", "Sunucu eklentisi yukleniyor")
+            .replace("Enabling ", "Etkinlestiriliyor ")
+            .replace("Disabling ", "Devre disi birakiliyor ")
+            .replace("Successfully enabled!", "Basariyla etkinlestirildi!")
+            .replace("Metrics initialized", "Metrikler baslatildi")
+            .replace("SQLite connection established.", "SQLite baglantisi kuruldu.")
+            .replace("Storage type:", "Depolama turu:")
+            .replace("Access URL:", "Erisim adresi:")
+            .replace("Starting background profiler...", "Arka plan profiler baslatiliyor...")
+            .replace("This server bundles the spark profiler. For more information please visit https://docs.papermc.io/paper/profiling", "Bu sunucu spark profiler'i yerlesik olarak tasir. Bilgi: https://docs.papermc.io/paper/profiling")
+            .replace("The spark plugin will not be loaded as this server bundles the spark profiler.", "Spark profiler HonorMC icinde yerlesik oldugu icin spark eklentisi yuklenmeyecek.")
+            .replace("The spark plugin has been preferred but was not loaded. The bundled spark profiler will enabled instead.", "Spark eklentisi tercih edildi fakat yuklenmedi; yerlesik spark profiler acilacak.")
+            .replace("The spark profiler will not be enabled because it is currently disabled in the configuration.", "Spark profiler ayarlarda kapali oldugu icin acilmayacak.")
+            .replace("The spark profiler is currently disabled.", "Spark profiler su anda kapali.")
+            .replace("The async-profiler engine is not supported for your os/arch", "Async-profiler motoru isletim sistemi/mimari icin desteklenmiyor")
+            .replace("so the built-in Java engine will be used instead.", "bu yuzden yerlesik Java motoru kullanilacak.");
+
+        translated = translated
+            .replaceAll("Loaded (\\d+) recipes", "$1 tarif yuklendi")
+            .replaceAll("Loaded (\\d+) advancements", "$1 ilerleme yuklendi")
+            .replaceAll("Starting minecraft server version (.+)", "Minecraft sunucu surumu baslatiliyor: $1")
+            .replaceAll("Server Ping Player Sample Count: (\\d+)", "Sunucu ping oyuncu ornek sayisi: $1")
+            .replaceAll("Using (\\d+) threads for Netty based IO", "Netty tabanli I/O icin $1 is parcacigi kullaniliyor")
+            .replaceAll("Default game type: (.+)", "Varsayilan oyun modu: $1")
+            .replaceAll("Starting Minecraft server on (.+)", "Minecraft sunucusu $1 adresinde aciliyor")
+            .replaceAll("Preparing level \"([^\"]+)\"", "Dunya hazirlaniyor: \"$1\"")
+            .replaceAll("Done preparing level \"([^\"]+)\" \\(([^)]+)\\)", "Dunya hazirlandi: \"$1\" ($2)")
+            .replaceAll("Loading (\\d+) persistent chunks for level '([^']+)'\\.\\.\\.", "$2 icin $1 kalici chunk yukleniyor...")
+            .replaceAll("Loading (\\d+) persistent chunks\\.\\.\\.", "$1 kalici chunk yukleniyor...")
+            .replaceAll("Prepared spawn area in (\\d+) ms", "Dogma alani $1 ms icinde hazirlandi")
+            .replaceAll("Saving chunks for level '([^']+)'/([^\\r\\n]+)", "Dunya chunklari kaydediliyor: '$1'/$2")
+            .replaceAll("Done \\(([^)]+)\\)! Yardim icin \"help\" yaz", "Hazir ($1)! Yardim icin \"help\" yaz")
+            .replaceAll("UUID of player ([^\\s]+) is ([0-9a-fA-F-]+)", "Oyuncu UUID bilgisi: $1 -> $2")
+            .replaceAll("([^\\r\\n]+) joined the game", "$1 oyuna katildi")
+            .replaceAll("([^\\r\\n]+) left the game", "$1 oyundan ayrildi")
+            .replaceAll("([^\\r\\n]+) logged in with entity id (\\d+) at \\(\\[([^\\]]+)\\]([^\\r\\n]+)\\)", "$1 varlik kimligi $2 ile giris yapti: [$3]$4")
+            .replaceAll("Server permissions file ([^\\r\\n]+) is empty, ignoring it", "Sunucu izin dosyasi $1 bos; yok sayiliyor")
+            .replaceAll("This server is running ([^\\r\\n]+) version ([^\\r\\n]+) \\(Implementing API version ([^)]+)\\)", "Bu sunucu $1 $2 surumuyle calisiyor (API surumu $3)")
+            .replaceAll("Error occurred while enabling ([^\\r\\n]+) \\(Is it up to date\\?\\)", "$1 etkinlestirilirken hata olustu (guncel mi?)");
+
+        return translated;
+    }
 }
diff --git a/src/main/java/io/papermc/paper/SparksFly.java b/src/main/java/io/papermc/paper/SparksFly.java
