index 0000000000000000000000000000000000000000..7c7c8aa3a0426466dd0278928745d323addd5179
--- /dev/null
+++ b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCConsoleStyles.java
@@ -0,0 +1,85 @@
+package io.papermc.paper.console;
+
+import org.apache.logging.log4j.Level;
+import org.apache.logging.log4j.Marker;
+import org.apache.logging.log4j.core.LogEvent;
+
+final class HonorMCConsoleStyles {
+    static final String CHAT_MARKER = "HONORMC_CHAT";
+
+    private static final String RESET = "\u001B[m";
+    private static final String GREEN = "\u001B[32m";
+    private static final String CYAN = "\u001B[36m";
+    private static final String CYAN_BOLD = "\u001B[36;1m";
+    private static final String YELLOW = "\u001B[33m";
+    private static final String YELLOW_BOLD = "\u001B[33;1m";
+    private static final String RED = "\u001B[31m";
+    private static final String RED_BOLD = "\u001B[31;1m";
+    private static final String BRIGHT_RED_BOLD = "\u001B[91;1m";
+    private static final String WHITE = "\u001B[37m";
+    private static final String DIM = "\u001B[90m";
+
+    private HonorMCConsoleStyles() {
+    }
+
+    static String label(final LogEvent event) {
+        if (isChat(event)) {
+            return "OYUNCU";
+        }
+
+        final Level level = event.getLevel();
+        return switch (level.getStandardLevel()) {
+            case FATAL -> "KRITIK";
+            case ERROR -> "HATA";
+            case WARN -> "UYARI";
+            case INFO -> "BILGI";
+            case DEBUG -> "DEBUG";
+            case TRACE -> "TRACE";
+            default -> level.name();
+        };
+    }
+
+    static String coloredLabel(final LogEvent event) {
+        return labelColor(event) + "[" + label(event) + "]" + RESET;
+    }
+
+    static String messageColor(final LogEvent event) {
+        if (isChat(event)) {
+            return CYAN;
+        }
+
+        return switch (event.getLevel().getStandardLevel()) {
+            case FATAL, ERROR -> RED;
+            case WARN -> YELLOW;
+            case INFO -> WHITE;
+            case DEBUG -> CYAN;
+            case TRACE -> DIM;
+            default -> WHITE;
+        };
+    }
+
+    static String reset() {
+        return RESET;
+    }
+
+    private static String labelColor(final LogEvent event) {
+        if (isChat(event)) {
+            return CYAN_BOLD;
+        }
+
+        return switch (event.getLevel().getStandardLevel()) {
+            case FATAL -> BRIGHT_RED_BOLD;
+            case ERROR -> RED_BOLD;
+            case WARN -> YELLOW_BOLD;
+            case INFO -> GREEN;
+            case DEBUG -> CYAN;
+            case TRACE -> DIM;
+            default -> WHITE;
+        };
+    }
+
+    private static boolean isChat(final LogEvent event) {
+        final Marker marker = event.getMarker();
+        return marker != null && (CHAT_MARKER.equals(marker.getName()) || marker.isInstanceOf(CHAT_MARKER));
+    }
+}
