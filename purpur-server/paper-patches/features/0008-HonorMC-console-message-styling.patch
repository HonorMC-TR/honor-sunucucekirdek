diff --git a/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java
new file mode 100644
index 0000000000000000000000000000000000000000..2e7a3d9c2b4d4c2e23cd516540b2c76df7f35bfa
--- /dev/null
+++ b/src/log4jPlugins/java/io/papermc/paper/console/HonorMCMessageConverter.java
@@ -0,0 +1,48 @@
+package io.papermc.paper.console;
+
+import java.util.List;
+import org.apache.logging.log4j.core.LogEvent;
+import org.apache.logging.log4j.core.config.Configuration;
+import org.apache.logging.log4j.core.config.plugins.Plugin;
+import org.apache.logging.log4j.core.layout.PatternLayout;
+import org.apache.logging.log4j.core.pattern.ConverterKeys;
+import org.apache.logging.log4j.core.pattern.LogEventPatternConverter;
+import org.apache.logging.log4j.core.pattern.PatternConverter;
+import org.apache.logging.log4j.core.pattern.PatternFormatter;
+import org.apache.logging.log4j.core.pattern.PatternParser;
+
+@Plugin(name = "honormcMessage", category = PatternConverter.CATEGORY)
+@ConverterKeys({"honormcMessage"})
+public final class HonorMCMessageConverter extends LogEventPatternConverter {
+    private final List<PatternFormatter> formatters;
+
+    private HonorMCMessageConverter(final List<PatternFormatter> formatters) {
+        super("honormcMessage", null);
+        this.formatters = formatters;
+    }
+
+    @Override
+    public void format(final LogEvent event, final StringBuilder toAppendTo) {
+        final int start = toAppendTo.length();
+        for (final PatternFormatter formatter : this.formatters) {
+            formatter.format(event, toAppendTo);
+        }
+
+        final String content = toAppendTo.substring(start);
+        toAppendTo.setLength(start);
+        toAppendTo
+            .append(HonorMCConsoleStyles.messageColor(event))
+            .append(content)
+            .append(HonorMCConsoleStyles.reset());
+    }
+
+    public static HonorMCMessageConverter newInstance(final Configuration config, final String[] options) {
+        if (options.length != 1) {
+            LOGGER.error("honormcMessage icin hatali secenek sayisi. Beklenen: 1, gelen: " + options.length);
+            return null;
+        }
+
+        final PatternParser parser = PatternLayout.createPatternParser(config);
+        return new HonorMCMessageConverter(parser.parse(options[0]));
+    }
+}
